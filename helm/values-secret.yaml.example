# =============================================================================
# SECRETS — Copier en values-secret.yaml et remplir toutes les valeurs
# Ce fichier est un modèle. values-secret.yaml est dans .gitignore.
#
# IMPORTANT : postgresql.auth.password DOIT être identique à secrets.postgresPassword
# =============================================================================

postgresql:
  auth:
    password: "CHANGE_ME_STRONG_PASSWORD_MIN_16_CHARS"

secrets:
  postgresUser: nexus
  postgresPassword: "CHANGE_ME_STRONG_PASSWORD_MIN_16_CHARS"   # identique à postgresql.auth.password
  postgresDb: nexus_diagnostix

  # Générer avec : openssl rand -hex 32
  secretKey: "CHANGE_ME_64_HEX_CHARS_JWT_SECRET"

  # Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
  fieldEncryptionKey: "CHANGE_ME_FERNET_BASE64_KEY"

  # Générer avec : openssl rand -hex 32
  pdfSigningSecret: "CHANGE_ME_32_CHARS_PDF_HMAC_SECRET"

  # Clé API Anthropic — récupérer sur console.anthropic.com
  anthropicApiKey: "CHANGE_ME_ANTHROPIC_API_KEY"

  # SMTP Gmail (App Password — pas le mot de passe du compte)
  smtpUser: "cti.intelligency@gmail.com"
  smtpPass: "CHANGE_ME_GMAIL_APP_PASSWORD"
  smtpFrom: "Nexus-Diagnostix <noreply@openlabconsulting.com>"

  # Compte admin initial (changé dès le premier login)
  initialAdminEmail: admin@openlabconsulting.com
  initialAdminPassword: "CHANGE_ME_ADMIN_PASSWORD_MIN_12_CHARS"
