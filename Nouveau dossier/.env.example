# =============================================================================
# Nexus-Diagnostix — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs.
# Ne JAMAIS committer .env.
# =============================================================================

# --- Environnement ---
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173,https://diagnostix.nexusrh.ci

# --- Sécurité ---
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_MIN_LENGTH=12
BCRYPT_ROUNDS=12

# Clé Fernet pour le chiffrement applicatif des colonnes sensibles (emails)
# Générer : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=changeme-generate-fernet-key

# Token signing pour URLs de PDF (HMAC-SHA256)
PDF_SIGNING_SECRET=changeme-32-chars-minimum
PDF_URL_TTL_DAYS=7

# --- Base de données ---
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
POSTGRES_DB=nexus_diagnostix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev_password@postgres:5432/nexus_diagnostix

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL_EXPERT=claude-opus-4-7
CLAUDE_MODEL_CHAT=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2000
CLAUDE_TEMPERATURE=0.3
CLAUDE_TIMEOUT_SECONDS=30

# --- Email (SendGrid ou SMTP) ---
EMAIL_PROVIDER=smtp                 # smtp | sendgrid
EMAIL_FROM=noreply@nexusrh.ci
EMAIL_FROM_NAME=NexusRH Diagnostix
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=changeme
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxx

# --- Stockage des PDFs ---
REPORTS_STORAGE_PATH=/var/data/reports
REPORTS_RETENTION_DAYS=730

# --- Rate limiting ---
RATELIMIT_PUBLIC_PER_MINUTE=60
RATELIMIT_LOGIN_PER_MINUTE=10
RATELIMIT_ADMIN_PER_MINUTE=600

# --- Captcha ---
HCAPTCHA_SITE_KEY=changeme
HCAPTCHA_SECRET_KEY=changeme

# --- Admin initial (créé au seed) ---
INITIAL_ADMIN_EMAIL=admin@openlabconsulting.com
INITIAL_ADMIN_PASSWORD=                 # vide → généré et affiché en console au premier démarrage

# --- ML ---
ML_MODELS_PATH=/app/ml_artifacts
ML_MIN_CONFIDENCE=0.60
